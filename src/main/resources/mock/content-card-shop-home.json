          "content": "<style>\n  @media (max-width: 640px) {\n    .section-8-container > img {\n      min-height: 220px;\n      object-fit: cover;\n    }\n    .section-8-wrapper {\n      padding-left: 1rem !important;\n      padding-top: 1rem !important;\n      padding-bottom: 1rem !important;\n      margin: 0 !important;\n    }\n    .section-8-wrapper h3 {\n      font-size: 1rem !important;\n      margin-bottom: 0.25rem !important;\n    }\n    .section-8-wrapper h6 {\n      font-size: 0.75rem !important;\n      margin-bottom: 0.5rem !important;\n      max-width: 80%;\n    }\n    .section-8-wrapper .section-8-buttons {\n      flex-direction: column;\n      gap: 0.5rem !important;\n      margin-top: 0.5rem !important;\n    }\n    .section-8-wrapper .section-8-button {\n      font-size: 0.7rem;\n      padding: 0.3rem 0.6rem !important;\n    }\n    .section-8-wrapper .section-8-button svg {\n      width: 6px;\n      height: 10px;\n    }\n  }\n</style>\n<div class=\"section-8-container relative w-full max-w-xl mx-auto\">\n  <img src=\"https://selfservice-staging.amdocsdigitalbss.cloud/api/media/file/Trail%20path%20banner.png\" alt=\"Section 8\" class=\"w-full h-auto rounded-xl\">\n  <div class=\"section-8-wrapper absolute top-0 left-0 bg-white/80 rounded-lg shadow-lg flex flex-col items-start m-4\" style=\"padding-left: 4rem; padding-top: 3.25rem; background: linear-gradient(90deg, rgba(0, 0, 0, 0.5) 31.41%, rgba(0, 0, 0, 0.1) 85.62%); height: 100%; width: 100%;\">\n    <h3 class=\"text-2xl font-bold mb-2 text-white\">Your plan, your way!</h3>\n    <h6 class=\"text-base mb-4 text-white\">\n      Choose a plan or start with a device and unlock our best prices ever\n    </h6>\n    <div class=\"section-8-buttons flex gap-3 mt-6\">\n      <button class=\"section-8-button flex gap-3 items-center bg-gray-200 text-white px-4 py-2 rounded-lg border border-gray-200 hover:bg-gray-300 transition\" style=\"border-radius: 100px; color: $PRIMARY_LIGHT$\">\n        <svg xmlns=\"http:/