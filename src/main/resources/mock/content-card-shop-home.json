        {
          "content": "<div style=\"max-width: 1152px; margin: 28px auto; border-radius: 12px; background: #fff; overflow: hidden; display: flex; flex-wrap: wrap; border: 1px solid #e5e7eb;\">\n  <div style=\"flex: 1; min-width: 300px; padding: 48px; display: flex; flex-direction: column; justify-content: center;\">\n    <span style=\"display: inline-block; background: #ccebff; color: #003D66; border-radius: 4px; padding: 4px 12px; font-size: 14px; margin-bottom: 24px; width: fit-content;\">\n      Samsung Galaxy\n    </span>\n    <h1 style=\"font-size: 48px; font-weight: 700; color: #1a1a1a; margin: 0 0 16px 0; line-height: 1.1;\">\n      Discover the Galaxy lineup\n    </h1>\n    <p style=\"font-size: 18px; color: #666; margin: 0 0 32px 0; line-height: 1.5;\">\n      From the flagship Galaxy S series to the versatile A series — find the Samsung device that fits your style.\n    </p>\n<a class=\"promotion-cta\"\n   data-href=\"/device-gallery?filters=DeviceBrand==Samsung\"\n   style=\"display: inline-block; background: #1a1a1a; color: #fff; padding: 12px 24px; border-radius: 50px; text-decoration: none; font-weight: 600; font-size: 16px; width: fit-content; cursor: pointer;\">\n  Explore Samsung devices\n</a>\n  </div>\n  <div style=\"flex: 1; min-width: 300px; display: flex; align-items: center; justify-content: center; padding: 32px;\">\n    <img src=\"https://images.samsung.com/is/image/samsung/assets/bg/smartphones/galaxy-s24-ultra/images/galaxy-s24-ultra-highlights-kv.jpg\"\n         alt=\"Samsung Galaxy\"\n         style=\"max-width: 100%; max-height: 400px; object-fit: contain;\" />\n  </div>\n</div>",
